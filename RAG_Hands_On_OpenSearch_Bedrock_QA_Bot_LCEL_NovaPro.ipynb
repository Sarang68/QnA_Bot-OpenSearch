## 🔧 Step 16: Production Enhancements

Add error handling and monitoring.
class ProductionQABot:
    """Production-ready Q&A Bot with error handling and monitoring (LCEL)."""

    def __init__(self, rag_chain, vectorstore):
        self.rag_chain = rag_chain
        self.vectorstore = vectorstore
        self.query_count = 0
        self.total_latency = 0
        self.errors = 0

    def ask(self, question: str, max_retries: int = 3) -> Dict:
        """Ask a question with basic error handling and retries."""
        attempt = 0
        last_error = None

        while attempt < max_retries:
            try:
                start = time.time()
                result = self.rag_chain.invoke(question)
                latency = time.time() - start

                self.query_count += 1
                self.total_latency += latency

                # Print logs for monitoring
                print(f"\n{'='*80}")
                print(f"💬 Question: {question}")
                print(f"{'='*80}")
                print(f"\n🤖 Answer:\n{result['answer']}")
                print(f"\n⏱️  Latency: {latency:.2f}s")

                print(f"\n📚 Top Sources:")
                for i, doc in enumerate(result['source_documents'][:3], 1):
                    print(f"\n{i}. {doc.metadata.get('filename', 'unknown-file')}")
                    print(f"   Chunk ID: {doc.metadata.get('chunk_id', 'N/A')}")
                    print(f"   Excerpt: {doc.page_content[:160]}...")

                return {
                    'answer': result['answer'],
                    'source_documents': result['source_documents'],
                    'success': True,
                    'latency': latency,
                    'attempt': attempt + 1 # +1 because attempt is 0-indexed
                }
            except Exception as e:
                attempt += 1
                last_error = e
                self.errors += 1
                print(f"\n⚠️  Error on attempt {attempt}/{max_retries}: {e}")
                time.sleep(1)

        print("\n❌ All retries failed.")
        return {
            'success': False,
            'error': str(last_error),
            'attempt': attempt
        }

    def metrics(self) -> Dict:
        """Return simple usage metrics."""
        if self.query_count > 0:
            success_count = self.query_count - self.errors
            success_rate = (success_count / self.query_count) * 100
            avg_latency = self.total_latency / success_count if success_count > 0 else 0.0
        else:
            success_rate = 0.0
            avg_latency = 0.0

        return {
            "total_queries": self.query_count,
            "successful": self.query_count - self.errors,
            "errors": self.errors,
            "success_rate": success_rate,
            "avg_latency": avg_latency,
            "total_latency": self.total_latency,
        }
# Create production bot
