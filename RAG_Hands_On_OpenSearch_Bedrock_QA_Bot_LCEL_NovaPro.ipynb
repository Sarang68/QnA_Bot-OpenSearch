## 📊 Step 15: Cost Monitoring

Estimate costs for this RAG system.
def estimate_rag_costs(num_queries: int, avg_input_tokens: int = 2000, avg_output_tokens: int = 500):
    """
    Estimate costs for Bedrock RAG system
    """
    # Bedrock pricing (us-east-1)
    titan_embed_cost_per_1k = 0.00002  # $0.00002 per 1K tokens
    claude_haiku_input_per_1m = 1.00   # $1.00 per 1M input tokens
    claude_haiku_output_per_1m = 5.00  # $5.00 per 1M output tokens

    # Embedding costs (for queries only, indexing is one-time)
    embedding_tokens = num_queries * avg_input_tokens
    embedding_cost = (embedding_tokens / 1000) * titan_embed_cost_per_1k

    # LLM costs
    total_input_tokens = num_queries * avg_input_tokens
    total_output_tokens = num_queries * avg_output_tokens

    llm_input_cost = (total_input_tokens / 1_000_000) * claude_haiku_input_per_1m
    llm_output_cost = (total_output_tokens / 1_000_000) * claude_haiku_output_per_1m

    total_cost = embedding_cost + llm_input_cost + llm_output_cost

    return {
        'num_queries': num_queries,
        'embedding_cost': embedding_cost,
        'llm_input_cost': llm_input_cost,
        'llm_output_cost': llm_output_cost,
        'total_cost': total_cost,
        'cost_per_query': total_cost / num_queries
    }

# Estimate for different usage levels
scenarios = [
    {"name": "Light Usage", "queries": 100},
