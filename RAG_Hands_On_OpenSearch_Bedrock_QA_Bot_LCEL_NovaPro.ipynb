    if response.lower() == 'yes':
        # Delete OpenSearch index
        try:
            opensearch_client.indices.delete(index=index_name)
            print(f"✅ Deleted OpenSearch index: {index_name}")
        except Exception as e:
            print(f"⚠️  Error deleting index: {s\tr(e)}")

        # Delete local files
        import shutil
        try:
            shutil.rmtree(docs_dir)
            print(f"✅ Deleted local documents: {docs_dir}/")
        except Exception as e:
            print(f"⚠️  Error deleting files: {str(e)}")

        print("\n✅ Cleanup complete!")
    else:
        print("\nℹ️  Resources retained. Remember to clean up later to avoid costs.")

# Uncomment to run cleanup
cleanup_resources()
