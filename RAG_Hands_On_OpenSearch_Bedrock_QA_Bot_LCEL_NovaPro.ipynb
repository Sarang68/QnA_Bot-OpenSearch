## 🔄 Step 14: Conversational RAG with Memory

Build a chatbot that remembers context.
# Conversational RAG with LCEL
# We'll maintain an explicit chat history as a list of messages.

chat_history: List = []  # List of HumanMessage / AIMessage


conv_prompt = ChatPromptTemplate.from_messages(
    [
        (
            "system",
            (
                "You are a helpful financial assistant. Use the retrieved context and the "
                "conversation history to answer the user's question. If the answer is not "
                "in the context, say you don't know."
            ),
        ),
        (
            "system",
            "Conversation so far:\n{chat_history}",
        ),
        (
            "human",
            "Question: {question}\n\nContext from retrieved chunks:\n{context}\n\nAnswer:",
        ),
    ]
)


def format_chat_history(history: List) -> str:
    """Render a list of messages as a simple transcript."""
    if not history:
        return "No previous conversation."
    lines = []
    for msg in history:
        if isinstance(msg, HumanMessage):
            lines.append(f"User: {msg.content}")
        elif isinstance(msg, AIMessage):
            lines.append(f"Assistant: {msg.content}")
    return "\n".join(lines)


# Conversational chain: (question, history, retrieved docs) -> answer
conv_chain = (
    {
        "question": RunnablePassthrough(),
        "chat_history": RunnableLambda(lambda _: format_chat_history(chat_history)),
        "context": retriever | RunnableLambda(format_docs),
    }
    | conv_prompt
    | llm
    | StrOutputParser()
)

